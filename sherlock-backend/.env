# Environment
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=shavi_dev_db
POSTGRES_USER=shavi_dev
POSTGRES_PASSWORD=devpassword

# SQLite Database
SQLITE_PATH=/home/tendayi/.hermes/hermes.db

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend
SERVE_FRONTEND=true
FRONTEND_DIR=/home/tendayi/Hermes-Amara/sherlock-visage/dist

# WebSocket
WEBSOCKET_PING_INTERVAL=20
WEBSOCKET_PING_TIMEOUT=20